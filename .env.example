# Nexus credentials — copy to .env and fill in your values
# Run: set -a && source .env && set +a
# (.env is gitignored)

# ChromaDB cloud (https://trychroma.com)
# Tenant is the UUID, not the URL slug — check your dashboard or API key page
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=default_database

# Voyage AI (https://voyageai.com)
VOYAGE_API_KEY=

# Anthropic — required for nx search --answer and nx pm archive
ANTHROPIC_API_KEY=
