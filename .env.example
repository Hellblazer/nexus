# Nexus credentials — copy to .env and fill in your values
# Run: set -a && source .env && set +a
# (.env is gitignored)
#
# NONE of these are required for a normal local install: `nx init` provisions
# everything (bundled PostgreSQL + pgvector, local bge-768 embedder) with no
# API keys. Fill in only what your setup actually uses.

# Managed / remote nexus service (service mode).
# Usually set via `nx config set` into ~/.config/nexus/config.yml instead of env;
# the env vars override config.yml when present.
NX_SERVICE_URL=
NX_SERVICE_TOKEN=

# Voyage AI (https://voyageai.com) — only for Voyage-embedded (cloud-mode)
# collections and the migration rehearsal's --with-cloud leg.
VOYAGE_API_KEY=

# Anthropic — only for the plan runner's claude -p operator dispatch
# (nx_answer / operators). Not needed for search or indexing.
ANTHROPIC_API_KEY=

# ── Legacy (pre-6.0 installs that have not migrated off ChromaDB Cloud) ──────
# CHROMA_API_KEY=
# CHROMA_TENANT=
# CHROMA_DATABASE=default_database
