[0.106, "o", "/demo-repo/docs/getting-started.md:0:## Authentication\r\r\n/demo-repo/docs/getting-started.md:1:\r\r\n/demo-repo/docs/getting-started.md:2:Uses JWT tokens with 24-hour expiry.\r\r\n/demo-repo/src/auth.py:1:def authenticate(user, password):\r\r\n/demo-repo/src/auth.py:2:    \"\"\"Verify credentials against the user store.\"\"\"\r\r\n/demo-repo/src/auth.py:3:    token = create_jwt(user, expiry_hours=24)\r\r\n/demo-repo/src/auth.py:4:    return token\r\r\n/demo-repo/docs/error-handling.md:0:# Error Handling\r\r\n/demo-repo/docs/error-handling.md:1:\r\r\n/demo-repo/docs/error-handling.md:2:All errors use structured logging via structlog.\r\r\n/demo-repo/docs/error-handling.md:3:Retry logic uses exponential backoff.\r\r\n/demo-repo/src/retry.py:1:class RetryHandler:\r\r\n/demo-repo/src/retry.py:2:    \"\"\"Exponential backoff with jitter.\"\"\"\r\r\n/demo-repo/src/retry.py:3:    def __init__(self, max_retries=3, base_delay=1.0):\r\r\n/demo-repo/src/retry.py:4:        self.max_retries = max_retries\r\r\n/demo-repo/src/retry.py:5:        self.base_delay = base_delay\r\r\n/d"]
