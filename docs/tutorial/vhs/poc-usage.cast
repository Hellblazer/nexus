[0.000, "o", "ry.py:6:\r\r\n/demo-repo/src/retry.py:7:    def execute(self, fn):\r\r\n/demo-repo/src/retry.py:8:        for attempt in range(self.max_retries):\r\r\n/demo-repo/src/retry.py:9:            try:\r\r\n/demo-repo/src/retry.py:10:                return fn()\r\r\n/demo-repo/src/retry.py:11:            except Exception:\r\r\n/demo-repo/src/retry.py:12:                delay = self.base_delay * (2 ** attempt)\r\r\n/demo-repo/src/retry.py:13:                time.sleep(delay)\r\r\n/demo-repo/src/retry.py:14:        raise RuntimeError(\"max retries exceeded\")\r\r\n/demo-repo/docs/getting-started.md:0:# Getting Started\r\r\n/demo-repo/docs/getting-started.md:1:\r\r\n/demo-repo/docs/getting-started.md:2:Install with pip, then run the server.\r\r\n"]
