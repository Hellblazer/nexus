<?xml version="1.0" encoding="UTF-8"?>
<!--
    RDR-152 nexus service — master Liquibase changelog.

    Includes all store-specific changelogs in dependency order.
    Add new <include> entries here as beads .11-.18 land.
-->
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <!-- Store 0: nexus_svc role bootstrap (bead nexus-9qvam) — MUST be first; the
         catalog grant DO-blocks and the final grants changeset are fail-loud when the
         role is absent, and build-time jOOQ codegen applies this changelog against a
         fresh container with no pre-hook. Idempotent; production DBA pre-creation
         makes it a no-op. -->
    <include file="db/changelog/role-001-nexus-svc.xml"/>

    <!-- Store 1: memory (bead nexus-gmiaf.5) -->
    <include file="db/changelog/memory-001-baseline.xml"/>

    <!-- Store 2: plans (bead nexus-gmiaf.11) -->
    <include file="db/changelog/plans-001-baseline.xml"/>

    <!-- Store 3: telemetry (bead nexus-gmiaf.12) -->
    <include file="db/changelog/telemetry-001-baseline.xml"/>

    <!-- Store 4: T1 scratch (bead nexus-gmiaf.13) — UNLOGGED, t1 schema, session+tenant scoped -->
    <include file="db/changelog/t1-001-baseline.xml"/>

    <!-- Store 5: taxonomy (bead nexus-gmiaf.14) — NO FTS; exact-equality + doc_count sort -->
    <include file="db/changelog/taxonomy-001-baseline.xml"/>

    <!-- Store 6: aspects / highlights / queue / promotion-log (bead nexus-gmiaf.15) -->
    <include file="db/changelog/aspects-001-baseline.xml"/>

    <!-- Store 7: chash_index (bead nexus-gmiaf.16) — content-addressed routing table, no FTS -->
    <include file="db/changelog/chash-001-baseline.xml"/>

    <!-- Store 8: catalog (bead nexus-gmiaf.18) — owners/documents/links/chunks/collections + FTS + RLS -->
    <include file="db/changelog/catalog-001-baseline.xml"/>

    <!-- Cross-store FKs (bead nexus-b7v6i) — (tenant_id, doc_id) → catalog_documents(tenant_id, tumbler).
         NOTE (nexus-sa14p): topic_assignments is intentionally EXCLUDED — its doc_id is a
         chunk chash, not a tumbler. aspects/highlights/queue/chunks keep their FKs. -->
    <include file="db/changelog/fk-001-catalog-cross-store.xml"/>

    <!-- Store 9: bridge token lifecycle (bead nexus-gmiaf.32.1) — service_tokens +
         session_tokens credential-resolution tables. NO RLS (read before tenant
         context exists; the token resolves the tenant). nexus schema. -->
    <include file="db/changelog/service-tokens-001-baseline.xml"/>

    <!-- Store 10: pgvector chunks tables + manifest collection column (bead nexus-mf447) -->
    <include file="db/changelog/vectors-001-baseline.xml"/>

    <!-- Store 10b: trigram GIN indexes for the hybrid pg_trgm gate (bead nexus-eap5l) -->
    <include file="db/changelog/vectors-002-trgm-index.xml"/>

    <!-- Collection-registry FKs (bead nexus-70r3c.2, RDR-156 P0.2):
         NOT VALID FKs from chunks_384/768/1024, chash_index, and topic_assignments to
         catalog_collections(tenant_id, name). Includes backfill-stubs changeset.
         Must come after vectors-001, chash-001, taxonomy-001, and catalog-001. -->
    <include file="db/changelog/fk-002-collection-registry.xml"/>

    <!-- Catalog hygiene (bead nexus-70r3c.2, RDR-156 P0.2):
         temporal typing for catalog_collections.created_at/superseded_at (TEXT→timestamptz NULL),
         and CHECK constraints for chash length = 32 and position >= 0. -->
    <include file="db/changelog/catalog-002-hygiene.xml"/>

    <!-- Soft-delete schema (bead nexus-70r3c.6, RDR-156 P1.2):
         deleted_at timestamptz NULL on catalog_documents + catalog_links; partial
         indexes WHERE deleted_at IS NULL; document_trash/document_restore/purge_trash
         functions; live_chunks anti-join view. ZERO triggers. -->
    <include file="db/changelog/catalog-003-soft-delete.xml"/>

    <!-- Manifest functions (bead nexus-70r3c.9, RDR-156 P2.2):
         nexus.manifest_orphans(dim int), nexus.manifest_backfill(), nexus.document_text(doc_id text).
         All SECURITY INVOKER, tombstone-aware (deleted_at IS NULL). Promotes the RDR-155
         generated-SQL-string artifacts to first-class DB objects. -->
    <include file="db/changelog/catalog-004-manifest-functions.xml"/>

    <!--
        Consolidated nexus_svc DML grants (bead nexus-net63) — runAlways="true".
        Must be LAST so all schema objects exist before grants are issued.
        Replaces the per-store IF-EXISTS-skip DO-blocks that silently skipped when
        nexus_svc was created after the first migration run.
    -->
    <include file="db/changelog/grants-nexus-svc.xml"/>

</databaseChangeLog>
