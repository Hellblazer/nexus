<?xml version="1.0" encoding="UTF-8"?>
<!--
    RDR-178 Gap 5 (bead nexus-melvx) — migration_jobs table.

    Production 2026-07-01: /v1/migration/ingest-cloud (RDR-176 P4) is synchronous;
    collections whose server-side copy exceeds ~60s outlive the nginx proxy timeout
    and 504 at the edge while the copy continues DETACHED (5 of 52 collections that
    night, all completed detached, verified only by polling dest counts afterward —
    the "fire, absorb the 504, poll until parity" operator hack). This table backs
    the async job contract that replaces the hack: POST returns 202 + job_id
    immediately; GET /v1/migration/jobs/{id} polls status; a bounded worker pool
    (2 concurrent) runs the actual copy.

    ── CREDENTIAL NON-PERSISTENCE (BINDING — 2026-07-02 gate-critique constraint) ──
    This table extends RDR-176's TEST-ENFORCED decision that ChromaCloud source
    credentials (source_api_key / source_tenant / source_database) are client-
    supplied, ephemeral, and NEVER persisted or logged. A jobs table exists
    precisely to survive engine restarts — if the credentials rode this row, that
    survival would silently defeat the RDR-176 non-persistence guarantee. THIS
    TABLE MUST NEVER GAIN a source_api_key / source_tenant / source_database
    column, nor any serialized-credential blob. Credentials live ONLY in the
    in-memory job context (method-local variables on the worker thread) for the
    duration of one copy run and are discarded with it. Enforced by
    MigrationHandlerIngestCloudTest#migrationJobsTable_hasNoCredentialColumns
    (queries information_schema.columns and asserts no credential-shaped name).

    Columns:
      job_id                 TEXT PK  — UUID string generated by the handler (app-
                                         generated, matching the t1.scratch id
                                         convention; see t1-001-baseline.xml).
      tenant_id               TEXT     — RLS discriminator (nexus.tenant GUC, same
                                         as every other T2 store).
      state                    TEXT     — queued | running | done | failed.
      collections               JSONB    — the requested collection-name array,
                                         VERBATIM (caller-supplied order), for
                                         audit/display.
      collections_key           TEXT     — canonical (sorted, deduped, JSON-array-
                                         encoded) key over the SAME collection set,
                                         used ONLY for the idempotency dedup index
                                         below (order-independent).
      per_collection_counts     JSONB    — {collection: {copied, dest, expected}},
                                         updated incrementally as each collection
                                         lands (progress signal for the poller).
      started_at / finished_at  TIMESTAMPTZ (nullable) — set on state transition.
      error                    TEXT (nullable) — on failure, the EXCEPTION TYPE
                                         ONLY (never the raw message — a Chroma
                                         error message can embed a third-party
                                         response body; same posture as the
                                         existing sync-path log statement in
                                         MigrationHandler).
      created_at                TIMESTAMPTZ NOT NULL DEFAULT now().

    Idempotency (design point 2 of the bead): a POST whose (tenant, collection-set)
    matches an already-queued-or-running job must return THAT job's id rather than
    starting a second copy. Enforced by a PARTIAL unique index on
    (tenant_id, collections_key) WHERE state IN ('queued','running') — at most one
    ACTIVE job per tenant per collection-set; completed/failed jobs are exempt so a
    later re-run of the same collection set is allowed.
-->
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <!-- ── Changeset 1: migration_jobs table + indexes ───────────────────────── -->
    <changeSet id="migration-001-1" author="nexus-melvx">
        <comment>Create nexus.migration_jobs — async ingest-cloud job tracking (RDR-178 Gap 5)</comment>
        <sql splitStatements="true" stripComments="false">
CREATE TABLE nexus.migration_jobs (
    job_id                TEXT         NOT NULL,
    tenant_id              TEXT         NOT NULL,
    state                   TEXT         NOT NULL DEFAULT 'queued',
    collections              JSONB        NOT NULL,
    collections_key          TEXT         NOT NULL,
    per_collection_counts    JSONB        NOT NULL DEFAULT '{}'::jsonb,
    started_at               TIMESTAMPTZ,
    finished_at              TIMESTAMPTZ,
    error                   TEXT,
    created_at               TIMESTAMPTZ  NOT NULL DEFAULT now(),
    CONSTRAINT migration_jobs_pk PRIMARY KEY (job_id),
    CONSTRAINT migration_jobs_state_chk CHECK (state IN ('queued', 'running', 'done', 'failed'))
);

-- Listing / recency queries (future doctor/stats orphan-job surface, RDR-177).
CREATE INDEX idx_migration_jobs_tenant_created ON nexus.migration_jobs (tenant_id, created_at DESC);

-- Idempotency (bead nexus-melvx design point 2): at most one ACTIVE (queued/running)
-- job per (tenant, collection-set). Completed/failed jobs are excluded so the same
-- collection set can be re-submitted after a prior run finishes.
CREATE UNIQUE INDEX idx_migration_jobs_active_dedup
    ON nexus.migration_jobs (tenant_id, collections_key)
    WHERE state IN ('queued', 'running');
        </sql>
        <rollback>DROP TABLE IF EXISTS nexus.migration_jobs CASCADE</rollback>
    </changeSet>

    <!-- ── Changeset 2: RLS enable + force + policy ──────────────────────────── -->
    <changeSet id="migration-001-2" author="nexus-melvx">
        <comment>Enable and force RLS; create tenant isolation policy</comment>
        <sql splitStatements="true" stripComments="false">
ALTER TABLE nexus.migration_jobs ENABLE ROW LEVEL SECURITY;
ALTER TABLE nexus.migration_jobs FORCE ROW LEVEL SECURITY;

CREATE POLICY tenant_isolation ON nexus.migration_jobs
    USING      (tenant_id = current_setting('nexus.tenant', true))
    WITH CHECK (tenant_id = current_setting('nexus.tenant', true));
        </sql>
        <rollback>
            DROP POLICY IF EXISTS tenant_isolation ON nexus.migration_jobs;
            ALTER TABLE nexus.migration_jobs NO FORCE ROW LEVEL SECURITY;
            ALTER TABLE nexus.migration_jobs DISABLE ROW LEVEL SECURITY;
        </rollback>
    </changeSet>

    <!--
        DML grants for nexus_svc are consolidated in grants-nexus-svc.xml
        (runAlways=true, ALL TABLES IN SCHEMA nexus) — no per-table grant here,
        matching the nexus-net63 convention every other store follows.
    -->

</databaseChangeLog>
