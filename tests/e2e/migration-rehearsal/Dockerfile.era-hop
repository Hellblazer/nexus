# syntax=docker/dockerfile:1
# RDR-185 P4.3 (nexus-n7u38.30) — ERA-SPANNING HOP validation box.
#
# Proves the RDR's Success Criterion end-to-end: an ANCIENT install — an old
# conexus release running its own old engine, holding a Chroma substrate with
# pre-RDR-108 chunk ids and store_put-only collections (the 2026-07-16 GH #1408
# work-instance shape) — reaches current via `nx upgrade` ALONE, unattended.
#
# Base = debian:trixie-slim (conexus's actual runtime deploy base, same as
# Dockerfile.cold / Dockerfile.package-upgrade). NOTHING the service needs is
# pre-staged: no native binary, no PG bundle, no ONNX model. BOTH engines — the
# era's own ($ERA_ENGINE_TAG, acquired by the OLD release's own pin) and the
# current one ($NEW_ENGINE_TAG, acquired by the ladder's engine precondition) —
# are fetched at runtime from the real published GitHub releases by the
# product's own code. The harness never supplies an engine binary: if it did,
# the hop would prove nothing about convergence.
#
# DELIBERATELY no `procps` (no `ps`), matching Dockerfile.package-upgrade: a
# real minimal-container deployment, where the product's process-skew detection
# must degrade that ONE leg gracefully rather than require procps everywhere.
# Do not add it back to make a leg pass — that papers over the GH #1402 class.
FROM debian:trixie-slim

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl git \
        python3 python3-venv python3-pip \
        libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Non-root user — initdb (run by `nx init --service`) refuses to run as root.
RUN useradd -m -s /bin/bash nexus
ENV PATH="/home/nexus/nxenv/bin:${PATH}"

RUN pip3 install --no-cache-dir --break-system-packages uv

USER nexus
WORKDIR /home/nexus

# The WORKING-TREE wheel, in its own subdirectory with its real PEP 427
# filename (pip/uv parse wheel filenames strictly) so it never collides with
# the driver's `pip install conexus==$ERA_RELEASE` from real PyPI into the same
# venv. This is the ONLY conexus artifact in the image.
COPY worktree-wheel/conexus-*.whl /home/nexus/worktree-wheel/
RUN --mount=type=cache,target=/home/nexus/.cache/uv,uid=1000,gid=1000 \
    uv venv --python 3.12 /home/nexus/nxenv

# The seeder runs under the venv's python, so it writes the legacy Chroma + T2
# + catalog through the ERA RELEASE's own libraries — the faithful pre-cutover
# on-disk state, including that era's T2 schema (which the ladder's t2-schema
# rung then has to migrate for real).
COPY seed_legacy.py /home/nexus/seed_legacy.py
COPY rehearse_era_hop.sh /home/nexus/rehearse_era_hop.sh

ENTRYPOINT ["/bin/bash", "/home/nexus/rehearse_era_hop.sh"]
